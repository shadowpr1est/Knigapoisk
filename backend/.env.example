POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT secret for auth-service (change in production)
JWT_SECRET_KEY=dev-secret

# Postgres DSNs per service (adjust host/DB names for prod)
AUTH_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/auth?sslmode=disable
BOOK_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/books?sslmode=disable
FILE_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/files?sslmode=disable
READING_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/reading?sslmode=disable
REVIEW_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/reviews?sslmode=disable

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=books
MINIO_USE_SSL=false

